# .env 配置文件

# 1. Telegram Bot Token (必填)
TG_TOKEN=your_telegram_bot_token_here

# 2. 允许操作的用户 ID (必填，数字)
ALLOWED_USER_ID=123456789

# 3. Mac Server 地址 (Docker 访问宿主机的特殊域名)
MAC_SERVER_URL=http://host.docker.internal:5001

# 4. Ollama 模型配置
OPENAI_API_BASE=http://host.docker.internal:11434/v1
MODEL_NAME=qwen3-coder:30b

# 5. Flink JobManager 地址（可选）
# 默认值: https://flink-jobmanager.big-data-platform.orb.local
FLINK_JOBMANAGER_URL=https://flink-jobmanager.big-data-platform.orb.local

# 6. Flink HTTPS 证书校验（可选）
# 生产环境建议保持为 true；如果公司内部是自签证书，可以设置为 false 来忽略证书校验。
# 例如: FLINK_VERIFY_SSL=false
FLINK_VERIFY_SSL=true

# 7. 需要在任务失败时自动重启的 Flink Job 容器名（可选）
# 例如: FLINK_JOB_CONTAINER=my-flink-job-container
FLINK_JOB_CONTAINER=flink-jobmanager