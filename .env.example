# .env 配置文件

# 1. Telegram Bot Token (必填)
TG_TOKEN=your_value_here

# 2. 允许操作的用户 ID (必填，数字)
ALLOWED_USER_ID=your_value_here

# 3. Mac Server 地址 (Docker 访问宿主机的特殊域名)
MAC_SERVER_URL=your_value_here

# 4. Ollama 模型配置
OPENAI_API_BASE=your_value_here
MODEL_NAME=your_value_here

FLINK_JOBMANAGER_URL=your_value_here
FLINK_VERIFY_SSL=your_value_here
FLINK_JOB_CONTAINER=your_value_here

FLINK_JOB_RESTART_CMD=your_value_here


# 可选：如果希望告警发到别的 chat（群聊等），可以单独指定
TELEGRAM_CHAT_ID=your_value_here

STREAM_PARK_URL=your_value_here
STREAMPARK_TOKEN=your_value_here